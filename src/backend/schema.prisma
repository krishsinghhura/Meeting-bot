generator client {
    provider = "prisma-client-js"
}

// replace YYOURPASSWORDHERE with your db password
datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model MeetingTranscript {
    id        String    @id @default(uuid())
    meetingId String    @unique
    createdAt DateTime
    segments  Segment[]
    artifacts MeetingArtifact[]
    aiResults MeetingAiResult[]
}

model MeetingSummary {
    id          String   @id @default(uuid())
    meetingId   String
    summaryText String
    generatedAt DateTime
    model       String
}

model Segment {
    id                String            @id @default(uuid())
    meetingId         String
    meetingTranscript MeetingTranscript @relation(fields: [meetingId], references: [meetingId])
    start             Int
    end               Int
    text              String
    speaker           String
    @@unique([meetingId, start])
}

model MeetingJob {
  id          String   @id @default(uuid())
  meetingUrl  String
  status      String   @default("pending")
  meetingId   String? 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MeetingArtifact {
  id                String            @id @default(uuid())
  meetingId         String
  meetingTranscript MeetingTranscript @relation(fields: [meetingId], references: [meetingId])
  kind              String
  mimeType          String
  storagePath       String
  fileSizeBytes     Int
  segmentCount      Int
  generatedAt       DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([meetingId, kind])
  @@index([meetingId])
}

model MeetingAiResult {
  id                String            @id @default(uuid())
  meetingId         String
  meetingTranscript MeetingTranscript @relation(fields: [meetingId], references: [meetingId])
  kind              String
  model             String
  outputJson        Json
  generatedAt       DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([meetingId, kind])
  @@index([meetingId])
}
